<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width,initial-scale=1" />
  <title>Login</title>
  <style>
    :root{
      --bg:#0f1724;
      --card:#0f17248a;
      --accent:#06b6d4;
      --accent-2:#7c3aed;
      --muted:#94a3b8;
      --white:#ffffff;
      --success:#10b981;
      --danger:#ef4444;
      --glass: rgba(255,255,255,0.05);
      font-family: Inter, system-ui, -apple-system, "Segoe UI", Roboto, "Helvetica Neue", Arial;
    }

    *{box-sizing:border-box}
    html,body{height:100%}
    body{
      margin:0;
      background:
        radial-gradient(800px 400px at 10% 10%, rgba(124,58,237,0.12), transparent 8%),
        radial-gradient(700px 350px at 90% 90%, rgba(6,182,212,0.07), transparent 8%),
        var(--bg);
      color:var(--white);
      display:flex;
      align-items:center;
      justify-content:center;
      padding:24px;
    }

    .wrap{
      width:100%;
      max-width:420px;
    }

    .card{
      background:linear-gradient(180deg, rgba(255,255,255,0.03), rgba(255,255,255,0.015));
      border-radius:14px;
      padding:28px;
      box-shadow: 0 10px 30px rgba(2,6,23,0.6), inset 0 1px 0 rgba(255,255,255,0.02);
      backdrop-filter: blur(6px);
      border:1px solid rgba(255,255,255,0.03);
    }

    .brand{
      display:flex;
      gap:12px;
      align-items:center;
      margin-bottom:18px;
    }
    .logo {
      width:46px;
      height:46px;
      border-radius:10px;
      display:grid;
      place-items:center;
      background:linear-gradient(135deg,var(--accent),var(--accent-2));
      box-shadow: 0 6px 18px rgba(124,58,237,0.18);
      font-weight:700;
      color:white;
      font-size:18px;
    }
    .brand h1{
      font-size:18px;
      margin:0;
      letter-spacing:0.2px;
    }
    .brand p{margin:0;font-size:13px;color:var(--muted)}

    form {margin-top:6px; display:flex; flex-direction:column; gap:12px}

    label{
      display:block;
      font-size:13px;
      color:var(--muted);
      margin-bottom:6px;
    }

    .field{
      position:relative;
    }

    input[type="text"],
    input[type="password"]{
      width:100%;
      padding:12px 44px 12px 12px;
      border-radius:10px;
      border:1px solid rgba(255,255,255,0.06);
      background:var(--glass);
      color:var(--white);
      outline:none;
      font-size:15px;
      transition: box-shadow .15s, border-color .15s, transform .08s;
    }

    input::placeholder{color:rgba(255,255,255,0.35); font-size:14px}

    input:focus{
      border-color: rgba(124,58,237,0.9);
      box-shadow: 0 6px 18px rgba(124,58,237,0.06);
      transform: translateY(-1px);
    }

    .icon-btn{
      position:absolute;
      right:8px;
      top:50%;
      transform:translateY(-50%);
      background:transparent;
      border:none;
      color:var(--muted);
      cursor:pointer;
      font-size:14px;
      padding:8px;
      border-radius:8px;
    }
    .icon-btn:focus{outline:2px solid rgba(6,182,212,0.18)}

    .row{
      display:flex;
      align-items:center;
      justify-content:space-between;
      gap:12px;
      font-size:13px;
      color:var(--muted);
    }
    .checkbox{
      display:flex;
      align-items:center;
      gap:8px;
    }
    .checkbox input{width:16px;height:16px}

    button[type="submit"]{
      margin-top:4px;
      background:linear-gradient(90deg,var(--accent), var(--accent-2));
      color:var(--white);
      padding:12px;
      border-radius:10px;
      border:none;
      cursor:pointer;
      font-weight:600;
      font-size:15px;
      transition: transform .12s, box-shadow .12s;
      box-shadow: 0 8px 18px rgba(12,38,63,0.45);
    }
    button[type="submit"]:active{transform:translateY(1px)}
    button[type="submit"]:hover{box-shadow:0 12px 30px rgba(124,58,237,0.18)}

    .hint{font-size:13px;color:var(--muted);text-align:center;margin-top:12px}
    .link{color:var(--accent);text-decoration:none}
    .small{font-size:12px;color:rgba(255,255,255,0.5)}

    .error{
      color:var(--danger);
      font-size:13px;
      margin-top:6px;
    }

    @media (max-width:420px){
      .card{padding:18px}
      .brand h1{font-size:16px}
    }
  </style>
</head>
<body>
  <div class="wrap">
    <div class="card" role="form" aria-labelledby="loginTitle">
      <form id="loginForm" action="/login" method="POST" novalidate>
        <div>
          <label for="username">Usuário</label>
          <div class="field">
            <input id="username" name="username" type="text" placeholder="seu.usuario" autocomplete="username" required aria-required="true" />
          </div>
        </div>

        <div>
          <label for="password">Senha</label>
          <div class="field">
            <input id="password" name="password" type="password" placeholder="••••••••" autocomplete="current-password" required aria-required="true" minlength="6" />
            <button type="button" class="icon-btn" id="togglePwd" aria-label="Mostrar senha">👁️</button>
          </div>
        </div>

        <div class="row">
          <label class="checkbox"><input type="checkbox" id="remember" name="remember" /> Lembrar-me</label>
          <a class="link small" href="#" onclick="alert('Funcionalidade de recuperação não implementada'); return false;">Esqueci a senha</a>
        </div>

        <div id="error" class="error" role="alert" aria-live="polite" style="display:none"></div>

        <button type="submit">Entrar</button>
      </form>

      <p class="hint">Novo aqui? <a class="link" href="#">Crie uma conta</a></p>
    </div>
  </div>

  <script>
    (function(){
      const form = document.getElementById('loginForm');
      const pwd = document.getElementById('password');
      const user = document.getElementById('username');
      const err = document.getElementById('error');
      const toggle = document.getElementById('togglePwd');

      toggle.addEventListener('click', () => {
        const shown = pwd.type === 'text';
        pwd.type = shown ? 'password' : 'text';
        toggle.textContent = shown ? '👁️' : '🙈';
        toggle.setAttribute('aria-label', shown ? 'Mostrar senha' : 'Ocultar senha');
      });

      form.addEventListener('submit', (e) => {
        err.style.display = 'none';
        err.textContent = '';

        // validação simples no cliente
        if (!user.value.trim() || !pwd.value) {
          e.preventDefault();
          err.style.display = 'block';
          err.textContent = 'Por favor, preencha usuário e senha.';
          ( !user.value.trim() ? user : pwd ).focus();
          return;
        }
        if (pwd.value.length < 6) {
          e.preventDefault();
          err.style.display = 'block';
          err.textContent = 'A senha deve ter pelo menos 6 caracteres.';
          pwd.focus();
          return;
        }

        // antes de enviar, opcional: sanitizar campos curtos (mas validação e parametrização no servidor é obrigatória)
        user.value = user.value.trim();
      });

      // tecla Enter no campo password foca submit (melhora acessibilidade)
      pwd.addEventListener('keydown', (ev) => {
        if (ev.key === 'Enter') form.querySelector('button[type="submit"]').click();
      });
    })();
  </script>
</body>
</html>